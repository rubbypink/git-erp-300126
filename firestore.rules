rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  	// Hàm Helper đọc level của User đang request
    function getUserLevel() {
      // Lấy dữ liệu user hiện tại từ collection users
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.level;
    }
    
    // ★ USERS COLLECTIONS - Cho phép read nếu user có role 'admin'
    match /users/{document=**} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == resource.id || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.level >= 50;
    }
    
    match /transactions/{transactionId} {
      // Cho phép Read/Create bình thường (kèm các rule của bạn nếu có)
      allow read, create: if request.auth != null;
      
      // XỬ LÝ GIAI ĐOẠN 2 TẠI ĐÂY:
      allow update, delete: if request.auth != null 
        && (
          resource.data.status != 'Completed' || getUserLevel() >= 50
        );
    }
        
    // ★ DEFAULT: Các collections khác - Yêu cầu auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}