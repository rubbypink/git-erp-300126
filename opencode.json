{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "watcher": {
        "ignore": ["node_modules/**", "dist/**", ".git/**"]
    },
    "disabled_providers": ["openai", "anthropic"],
    "permission": {
        "skill": {
          "*": "allow",
          "pr-review": "allow",
          "internal-*": "allow",
          "experimental-*": "ask"
        }
      }
}
